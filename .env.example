NEXT_PUBLIC_DEFAULT_NETWORK=ethereum
ETH_RPC_URL=
ARB_RPC_URL=
AVAX_RPC_URL=
SOL_RPC_URL=
NEXT_PUBLIC_ETH_RPC_URL=
NEXT_PUBLIC_ARB_RPC_URL=
NEXT_PUBLIC_AVAX_RPC_URL=
NEXT_PUBLIC_SOL_RPC_URL=
NEXT_PUBLIC_LIFI_INTEGRATOR=wallet2qr
NEXT_PUBLIC_LIFI_FEE_BPS=50
NEXT_PUBLIC_LIFI_FEE_RECEIVER=0x...

# THORChain affiliate (thor1... address or registered THORName)
# THOR_AFFILIATE is for server-side only code (admin dashboard); avoids
# the NEXT_PUBLIC_ build-time inlining issue.
THOR_AFFILIATE=
NEXT_PUBLIC_THOR_AFFILIATE=
NEXT_PUBLIC_THOR_AFFILIATE_BPS=30

# WalletConnect (get project ID at cloud.reown.com)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Admin dashboard
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_SECRET=
AUTH_URL=https://wallet2qr.com
ADMIN_EMAIL=alex@vir-tec.net
BLOB_READ_WRITE_TOKEN=
